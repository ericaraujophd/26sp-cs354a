icial differences such as aliasing, whitespace, clause reordering, or reformatted joins.","position":{"start":{"line":103,"column":1},"end":{"line":103,"column":1}},"key":"MoumIXZBcj"}],"key":"fF1PlJKTji"}],"class":"warning","key":"jA5DQM1CHZ"},{"type":"thematicBreak","position":{"start":{"line":106,"column":1},"end":{"line":106,"column":1}},"key":"XWrmmVMRdA"},{"type":"heading","depth":3,"position":{"start":{"line":108,"column":1},"end":{"line":108,"column":1}},"children":[{"type":"text","value":"Shared Database Environments","position":{"start":{"line":108,"column":1},"end":{"line":108,"column":1}},"key":"jfAQ3ufEOo"}],"identifier":"shared-database-environments","label":"Shared Database Environments","html_id":"shared-database-environments","implicit":true,"key":"hywx2QcIIM"},{"type":"paragraph","position":{"start":{"line":110,"column":1},"end":{"line":110,"column":1}},"children":[{"type":"text","value":"In this course you will work with a shared PostgreSQL server. Each student has their own schema and data. ","position":{"start":{"line":110,"column":1},"end":{"line":110,"column":1}},"key":"cFthJJqJWM"},{"type":"strong","position":{"start":{"line":110,"column":1},"end":{"line":110,"column":1}},"children":[{"type":"text","value":"Accessing, querying, inspecting, or modifying another student’s tables, schemas, or data — even without malicious intent — constitutes academic dishonesty","position":{"start":{"line":110,"column":1},"end":{"line":110,"column":1}},"key":"JClO7i7yXn"}],"key":"vbTKYyjAcM"},{"type":"text","value":" and will be treated accordingly. Stick to your own schema unless a collaborative assignment explicitly instructs otherwise.","position":{"start":{"line":110,"column":1},"end":{"line":110,"column":1}},"key":"BJXtNUVMk8"}],"key":"HQsEoFgQCm"},{"type":"thematicBreak","position":{"start":{"line":112,"column":1},"end":{"line":112,"column":1}},"key":"hp1cF4HCsh"},{"type":"heading","depth":3,"position":{"start":{"line":114,"column":1},"end":{"line":114,"c